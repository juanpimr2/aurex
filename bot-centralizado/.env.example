# ============================================================
# BOT MILLONARIO - Variables de Entorno
# ============================================================
# COPIA este archivo como .env y rellena tus credenciales
# NUNCA subas el archivo .env a GitHub

# --- Capital.com Credenciales ---
CAPITAL_API_KEY=tu_api_key_aqui
CAPITAL_PASSWORD=tu_password_aqui
CAPITAL_EMAIL=tu_email_aqui

# --- Modo (REAL o DEMO) ---
# DEMO = https://demo-api-capital.backend-capital.com/api/v1
# REAL = https://api-capital.backend-capital.com/api/v1
CAPITAL_MODE=DEMO

# --- Configuracion del Bot ---
INITIAL_CAPITAL=300
RISK_PER_TRADE=1.5
MAX_POSITIONS=2
