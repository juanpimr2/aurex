# ============================================================
# AUREX — Environment Configuration
# ============================================================
# Copy this file to bot-centralizado/backend/.env
# and fill in your own values. Never commit .env to git.
# ============================================================

# --- Capital.com API Credentials ---
# Get your API key: Capital.com → Settings → API Management
CAPITAL_API_KEY=YOUR_API_KEY_HERE
CAPITAL_PASSWORD=YOUR_ACCOUNT_PASSWORD
CAPITAL_EMAIL=your@email.com

# --- Trading Mode ---
# DEMO  → paper trading (safe, use this first)
# REAL  → live trading with real money (use with caution)
CAPITAL_MODE=DEMO

# --- Risk Management ---
INITIAL_CAPITAL=300        # Your starting capital in account currency
RISK_PER_TRADE=1.5         # % of equity risked per trade (recommended: 1–2%)
MAX_POSITIONS=2            # Maximum simultaneous open positions
